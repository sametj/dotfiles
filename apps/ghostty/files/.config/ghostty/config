# Font
font-family = JetBrainsMono Nerd Font
font-size = 14

# Window
window-padding-x = 10
window-padding-y = 10
window-decoration = true

# Cursor
cursor-style = block
cursor-style-blink = true

# Theme
theme = Catppuccin Frappe

# Scrollback
scrollback-limit = 100000

# Copy / Paste
copy-on-select = true

# macOS specific
macos-option-as-alt = true

# Shell integration
shell-integration = zsh
