{
  "$help": "https://aka.ms/terminal-documentation",
  "$schema": "https://aka.ms/terminal-settings-schema",

  "defaultProfile": "{2c4de342-38b7-51cf-b940-2309a097f518}",
  "copyOnSelect": false,
  "copyFormatting": "none",
  "trimBlockSelection": true,
  "wordDelimiters": " /\\()\"'-.,:;<>~!@#$%^&*|+=[]{}~?\u2502",

  "profiles": {
    "defaults": {
      "font": {
        "face": "JetBrainsMono Nerd Font",
        "size": 16,
        "weight": "normal"
      },
      "colorScheme": "GitHub Dark Default",
      "cursorShape": "filledBox",
      "cursorColor": "#2f81f7",
      "opacity": 100,
      "useAcrylic": false,
      "scrollbarState": "hidden",
      "historySize": 100000,
      "antialiasingMode": "cleartype",
      "padding": "10"
    },
    "list": [
      {
        "name": "Ubuntu (WSL)",
        "guid": "{2c4de342-38b7-51cf-b940-2309a097f518}",
        "source": "Windows.Terminal.Wsl",
        "commandline": "wsl.exe ~ -d Ubuntu",
        "startingDirectory": "~",
        "icon": "https://assets.ubuntu.com/v1/49a1a858-favicon-32x32.png"
      },
      {
        "name": "PowerShell",
        "guid": "{574e775e-4f2a-5b96-ac1e-a2962a402336}",
        "source": "Windows.Terminal.PowershellCore",
        "hidden": false
      },
      {
        "name": "Command Prompt",
        "guid": "{0caa0dad-35be-5f56-a8ff-afceeeaa6101}",
        "commandline": "%SystemRoot%\\System32\\cmd.exe",
        "hidden": false
      }
    ]
  },

  "schemes": [
    {
      "name": "GitHub Dark Default",
      "background": "#0d1117",
      "foreground": "#e6edf3",
      "cursorColor": "#2f81f7",
      "selectionBackground": "#e6edf3",
      "selectionForeground": "#0d1117",
      "black": "#484f58",
      "red": "#ff7b72",
      "green": "#3fb950",
      "yellow": "#d29922",
      "blue": "#58a6ff",
      "purple": "#bc8cff",
      "cyan": "#39c5cf",
      "white": "#b1bac4",
      "brightBlack": "#6e7681",
      "brightRed": "#ffa198",
      "brightGreen": "#56d364",
      "brightYellow": "#e3b341",
      "brightBlue": "#79c0ff",
      "brightPurple": "#d2a8ff",
      "brightCyan": "#56d4dd",
      "brightWhite": "#ffffff"
    }
  ],

  "actions": [
    { "command": { "action": "copy",  "singleLine": false }, "keys": "ctrl+c" },
    { "command": "paste",                                     "keys": "ctrl+v" },
    { "command": "find",                                      "keys": "ctrl+shift+f" },
    { "command": { "action": "splitPane", "split": "auto", "splitMode": "duplicate" }, "keys": "alt+shift+d" },
    { "command": { "action": "newTab"  }, "keys": "ctrl+t" },
    { "command": { "action": "closeTab" }, "keys": "ctrl+w" },
    { "command": { "action": "nextTab" }, "keys": "ctrl+tab" },
    { "command": { "action": "prevTab" }, "keys": "ctrl+shift+tab" },
    { "command": { "action": "scrollUp",   "rowsToScroll": 5 }, "keys": "ctrl+shift+up" },
    { "command": { "action": "scrollDown", "rowsToScroll": 5 }, "keys": "ctrl+shift+down" }
  ]
}
